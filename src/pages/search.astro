---
import Layout from '~/layouts/PageLayout.astro';
const metadata = { title: 'Pencarian Laporan — Exprosig' };
---

<Layout metadata={metadata}>
  <section class="px-4 py-20 mx-auto max-w-4xl min-h-screen">
    <div class="mb-10 text-center">
      <h1 class="text-4xl font-bold mb-4">Cari Laporan & Data</h1>
      <p class="text-muted">Temukan data Kiln, TKDN, atau laporan mingguan dengan cepat.</p>
    </div>

    <div id="search" class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm"></div>

    <link href="/_pagefind/pagefind-ui.css" rel="stylesheet" />
    <script src="/_pagefind/pagefind-ui.js" is:inline></script>

    <script is:inline>
      document.addEventListener('astro:page-load', () => {
        if (document.querySelector('#search')) {
          new PagefindUI({
            element: "#search",
            showSubResults: true,
            autofocus: true, // Langsung fokus saat halaman dibuka
            translations: { placeholder: "Ketik kata kunci (misal: TKDN, Kiln 1, Januari)..." }
          });
        }
      });
    </script>
  </section>
</Layout>