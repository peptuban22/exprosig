---
import Layout from '~/layouts/PageLayout.astro';
const metadata = { title: 'Pencarian Laporan — Exprosig' };
---

<Layout metadata={metadata}>
  <section class="px-4 py-20 mx-auto max-w-4xl min-h-screen">
    <div class="mb-10 text-center">
      <h1 class="text-4xl font-bold mb-4">Cari Laporan & Data</h1>
      <p class="text-muted text-lg text-slate-600 dark:text-slate-400">
        Temukan data Kiln, TKDN, atau laporan mingguan dengan cepat.
      </p>
    </div>

    <div id="search" class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm min-h-[200px]"></div>

    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <script src="/pagefind/pagefind-ui.js" is:inline></script>

    <script is:inline>
      function initSearch() {
        // Cek apakah PagefindUI sudah termuat dari script eksternal
        if (typeof PagefindUI !== "undefined") {
          const el = document.querySelector('#search');
          if (el) {
            // Bersihkan elemen untuk mencegah duplikasi UI saat navigasi balik
            el.innerHTML = ""; 
            
            new PagefindUI({
              element: "#search",
              bundlePath: "/pagefind/", 
              showSubResults: true,
              autofocus: true,
              translations: {
                placeholder: "Ketik kata kunci (TKDN, Kiln, Reliability)...",
                zero_results: "Data tidak ditemukan untuk [SEARCH_TERM]"
              }
            });
          }
        } else {
          // Jika gagal, coba inisialisasi ulang setelah jeda singkat
          setTimeout(initSearch, 500);
        }
      }

      // Inisialisasi saat pertama kali load
      window.addEventListener('DOMContentLoaded', initSearch);
      
      // Inisialisasi ulang saat perpindahan halaman via View Transitions
      document.addEventListener('astro:page-load', initSearch);
    </script>
  </section>
</Layout>