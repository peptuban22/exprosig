---
import Layout from '~/layouts/PageLayout.astro';
const metadata = { title: 'Pencarian Laporan — Exprosig' };
---

<Layout metadata={metadata}>
  <section class="px-4 py-20 mx-auto max-w-4xl min-h-screen">
    <div class="mb-10 text-center">
      <h1 class="text-4xl font-bold mb-4">Cari Laporan & Data</h1>
      <p class="text-muted text-lg">Temukan data Kiln, TKDN, atau laporan mingguan dengan cepat.</p>
    </div>

    <div id="search" class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm min-h-[200px]"></div>

    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <script src="/pagefind/pagefind-ui.js" is:inline></script>

    <script is:inline>
      function initSearch() {
        const selector = "#search";
        const el = document.querySelector(selector);
        
        // Hapus isi sebelumnya jika ada (mencegah duplikasi/input freeze)
        if (el) el.innerHTML = ""; 

        if (typeof PagefindUI !== "undefined") {
          new PagefindUI({
            element: selector,
            bundlePath: "/pagefind/", // Pastikan diakhiri slash
            showSubResults: true,
            autofocus: true,
            translations: { 
              placeholder: "Ketik kata kunci (misal: TKDN, Kiln 1, Januari)..." 
            }
          });
        }
      }

      // Inisialisasi saat halaman pertama dimuat
      window.addEventListener('DOMContentLoaded', initSearch);
      
      // Inisialisasi ulang saat navigasi Astro (View Transitions)
      document.addEventListener('astro:page-load', initSearch);
    </script>
  </section>
</Layout>