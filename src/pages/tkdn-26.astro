---
import Layout from '~/layouts/PageLayout.astro';
const metadata = { title: 'Progress TKDN GOPO 2026 — Exprosig' };
---

<Layout metadata={metadata}>
  <section class="px-4 py-16 mx-auto max-w-7xl">
    <div class="max-w-xl mb-10 md:mx-auto sm:text-center lg:max-w-2xl md:mb-12">
      <h2 class="text-3xl font-bold leading-tighter tracking-tighter mb-4 font-heading">
        Progress TKDN GOPO 2026
      </h2>
      <p id="last-updated" class="text-xs text-teal-600 font-medium italic">Menghubungkan data...</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
      
      <div class="p-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl shadow-sm flex flex-col justify-between">
        <div class="flex justify-between items-start mb-2">
          <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Pencapaian Proyek</p>
          <span id="main-pct-text" class="text-xs font-bold text-teal-600 bg-teal-50 px-2 py-0.5 rounded-full">0%</span>
        </div>
        
        <div class="grid grid-cols-2 gap-2 mb-4">
          <div>
            <p class="text-[10px] text-slate-400 uppercase">Total Target</p>
            <h3 id="total-target-val" class="text-lg font-bold text-slate-700 dark:text-white leading-none">0 M</h3>
          </div>
          <div class="border-l border-slate-100 pl-2">
            <p class="text-[10px] text-teal-600 uppercase font-bold">Realisasi s/d</p>
            <h3 id="total-realisasi-val" class="text-lg font-bold text-teal-600 leading-none">0 M</h3>
          </div>
        </div>

        <div class="w-full bg-slate-100 dark:bg-slate-800 rounded-full h-1.5">
          <div id="main-progress-bar" class="bg-teal-600 h-full transition-all duration-1000" style="width: 0%"></div>
        </div>
      </div>

      <div class="md:col-span-2 p-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl shadow-sm flex items-center justify-between">
        <div class="w-1/3">
          <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Status Progres</p>
          <p class="text-xs text-slate-500 leading-tight">Perbandingan realisasi terhadap sisa target bulan terkini.</p>
        </div>
        <div class="w-2/3 flex justify-end">
          <div id="tkdn-donut-chart" style="min-height: 120px !important;"></div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <div class="p-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-sm">
        <h3 class="text-sm font-bold mb-6 text-slate-700 dark:text-white uppercase border-b pb-2">Trend Total Realisasi TKDN 2026 (Monthly)</h3>
        <div id="monthly-bar-chart"></div>
      </div>
      <div class="p-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-sm">
        <h3 class="text-sm font-bold mb-6 text-slate-700 dark:text-white uppercase border-b pb-2">Trend Realisasi s/d (Cumulative)</h3>
        <div id="cumulative-line-chart"></div>
      </div>
    </div>
  </section>

  <script>
    import Papa from 'papaparse';
    import ApexCharts from 'apexcharts';

    const TKDN_COLORS = { teal: '#0d9488', blue: '#3b82f6', gray: '#f1f5f9' };

    // Helper Fungsi Global di dalam script
    const parseNum = (val) => {
      if (!val || typeof val !== 'string') return 0;
      const clean = val.replace(/["%,]/g, ""); // Hapus tanda kutip, persen, dan koma
      return parseFloat(clean) || 0;
    };

    async function startTKDN() {
      const csvUrl = 'https://docs.google.com/spreadsheets/d/14Mv4OYfHhkb7qUtsszHOMAVlzwR21wvCrG3qxzHpdiI/export?format=csv&gid=1722041104';
      
      try {
        const response = await fetch(csvUrl);
        const csvString = await response.text();
        const { data } = Papa.parse(csvString, { header: true, skipEmptyLines: true });

        if (!data || data.length === 0) return;

        // 1. Ambil Nilai Maksimal dengan aman
        const targetValues = data.map(r => parseNum(r['Target s/d']));
        const realisasiValues = data.map(r => parseNum(r['Realisasi s/d']));
        
        const maxTargetSD = Math.max(...targetValues, 0);
        const maxRealisasiSD = Math.max(...realisasiValues, 0);
        const totalPct = maxTargetSD > 0 ? (maxRealisasiSD / maxTargetSD) * 100 : 0;

        // Update DOM dengan pengecekan ID agar tidak error
        const elTarget = document.getElementById('total-target-val');
        const elReal = document.getElementById('total-realisasi-val');
        const elPctText = document.getElementById('main-pct-text');
        const elPBar = document.getElementById('main-progress-bar');

        if (elTarget) elTarget.innerText = (maxTargetSD / 1e9).toFixed(2).replace('.', ',') + ' M';
        if (elReal) elReal.innerText = (maxRealisasiSD / 1e9).toFixed(2).replace('.', ',') + ' M';
        if (elPctText) elPctText.innerText = totalPct.toFixed(2).replace('.', ',') + '%';
        if (elPBar) setTimeout(() => elPBar.style.width = Math.min(totalPct, 100) + '%', 500);

        // 2. Cari Record Bulan Terkini (yang ada realisasinya)
        const activeRows = data.filter(r => parseNum(r['Realisasi s/d']) > 0);
        const latest = activeRows.length > 0 ? activeRows[activeRows.length - 1] : data[0];
        
        const currentRealSD = parseNum(latest['Realisasi s/d']);
        const currentRem = parseNum(latest['Remaining progres']);

        // 3. Render Charts
        renderDonut(currentRealSD, currentRem);
        renderBar(data);
        renderLine(data);

        const elUpdated = document.getElementById('last-updated');
        if (elUpdated) elUpdated.innerText = `Sync: ${new Date().toLocaleString('id-ID')} WIB`;

      } catch (err) {
        console.error("Dashboard Error:", err);
      }
    }

    function renderDonut(real, remain) {
      const pct = (real / (real + remain)) * 100;
      new ApexCharts(document.querySelector("#tkdn-donut-chart"), {
        series: [real, remain],
        chart: { 
          type: 'donut', 
          height: 140, // DIKECILKAN dari 280
          sparkline: { enabled: true } // Menghilangkan whitespace berlebih
        },
        colors: [TKDN_COLORS.teal, TKDN_COLORS.gray],
        labels: ['Real s/d', 'Remaining'],
        plotOptions: { 
          pie: { 
            donut: { 
              size: '75%', 
              labels: { 
                show: true, 
                total: { 
                  show: true, 
                  label: '', // Menghilangkan label tengah untuk menghemat ruang
                  formatter: () => pct.toFixed(1).replace('.', ',') + '%' 
                } 
              } 
            } 
          } 
        },
        dataLabels: { enabled: false },
        legend: { show: false } // Legend dihilangkan agar lebih bersih
      }).render();
    }

    function renderBar(data) {
      const chartEl = document.querySelector("#monthly-bar-chart");
      if (!chartEl) return;

      new ApexCharts(chartEl, {
        series: [
          { name: 'Target', data: data.map(r => parseNum(r['Target']) / 1e9) },
          { name: 'Realisasi', data: data.map(r => parseNum(r['Realisasi']) / 1e9) }
        ],
        chart: { type: 'bar', height: 320, toolbar: { show: false } },
        colors: [TKDN_COLORS.blue, TKDN_COLORS.teal],
        xaxis: { categories: data.map(r => r.Bulan || r.Month) },
        // PERBAIKAN SUMBU Y
        yaxis: { 
          title: { text: 'Milyar' },
          labels: { 
            formatter: (val) => val.toFixed(0) // Menampilkan 5, 10, 15 dst
          } 
        },
        dataLabels: { enabled: false },
        legend: { position: 'top' }
      }).render();
    }

    function renderLine(data) {
      const chartEl = document.querySelector("#cumulative-line-chart");
      if (!chartEl) return;

      const realSeries = data.map(r => {
        const val = parseNum(r['Realisasi s/d']);
        return val > 0 ? (val / 1e9) : null;
      });

      new ApexCharts(chartEl, {
        series: [
          { name: 'Target s/d', data: data.map(r => parseNum(r['Target s/d']) / 1e9) },
          { name: 'Realisasi s/d', data: realSeries }
        ],
        chart: { type: 'line', height: 320, toolbar: { show: false } },
        colors: [TKDN_COLORS.blue, TKDN_COLORS.teal],
        stroke: { curve: 'smooth', width: 4 },
        markers: { size: 4 },
        xaxis: { categories: data.map(r => r.Bulan || r.Month) },
        // PERBAIKAN SUMBU Y
        yaxis: { 
          title: { text: 'Milyar' },
          labels: { 
            formatter: (val) => val.toFixed(0) 
          } 
        },
        tooltip: { 
          shared: true, 
          y: { 
            formatter: v => v ? v.toFixed(2).replace('.', ',') + " Milyar" : "No Data" 
          } 
        }
      }).render();
    }

    startTKDN();
  </script>
</Layout>