---
import Layout from '~/layouts/PageLayout.astro';
import Papa from 'papaparse';

const metadata = { title: 'Exprosig — Dashboard Performance' };

let stats = [];
let chartData = { labels: [], series: [] };
let errorMsg = "";

try {
  // 1. Fetch data dari Google Sheets (format CSV)
  const response = await fetch('https://docs.google.com/spreadsheets/d/12Qy1QBVDLG9g1VgySGML5EgQc-90rHhw_JT58_eta6Q/export?format=csv&gid=0');
  
  if (!response.ok) throw new Error("Gagal mengambil data dari Google Sheets");
  
  const csvString = await response.text();

  // 2. Parse CSV ke JSON
  const { data } = Papa.parse(csvString, { 
    header: true, 
    skipEmptyLines: true 
  });

  const kilnList = ['Kiln 1', 'Kiln 2', 'Kiln 3', 'Kiln 4'];

  // 3. Fungsi untuk menghitung TOTAL PRODUKSI (Sum)
  const getTotalProduction = (kilnName) => {
    return data
      .filter(row => row.KILN === kilnName)
      .reduce((sum, row) => {
        // Membersihkan karakter non-angka agar aman saat dijumlahkan
        const cleanValue = row.Production ? row.Production.replace(/[^0-9.-]+/g, "") : "0";
        return sum + (parseFloat(cleanValue) || 0);
      }, 0);
  };

  // 4. Siapkan data untuk Scorecards
  stats = kilnList.map(name => ({
    title: `Total Production ${name}`,
    amount: getTotalProduction(name)
  }));

  // 5. Siapkan data untuk Chart
  chartData = {
    labels: kilnList,
    series: stats.map(s => s.amount)
  };

} catch (e) {
  errorMsg = e.message;
}
---

<Layout metadata={metadata}>
  <section class="px-4 py-16 mx-auto max-w-7xl">
    {errorMsg ? (
      <div class="p-4 bg-red-100 text-red-700 rounded-lg">Error: {errorMsg}</div>
    ) : (
      <>
        <div class="max-w-xl mb-10 md:mx-auto sm:text-center lg:max-w-2xl md:mb-12">
          <h2 class="text-3xl font-bold leading-tighter tracking-tighter mb-4 font-heading">
            Kiln Production Performance 2026
          </h2>
          <p class="text-muted dark:text-slate-400">Akumulasi total produksi tahunan per unit kiln.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
          {stats.map(({ title, amount }) => (
            <div class="flex flex-col p-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg shadow-sm">
              <p class="text-xs font-medium uppercase tracking-widest text-teal-600 dark:text-teal-400">{title}</p>
              <p class="text-2xl font-bold mt-2">
                {new Intl.NumberFormat('id-ID').format(amount.toFixed(0))} <span class="text-sm font-normal text-muted">Tons</span>
              </p>
            </div>
          ))}
        </div>

        <div class="p-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg shadow-sm">
          <h3 class="text-xl font-bold mb-6 text-center text-slate-800 dark:text-white">Visualisasi Perbandingan Produksi</h3>
          
          <div 
            id="kiln-bar-chart" 
            data-labels={JSON.stringify(chartData.labels)} 
            data-series={JSON.stringify(chartData.series)}
          ></div>
        </div>
      </>
    )}
  </section>

  <script>
    import ApexCharts from 'apexcharts';

    const chartElement = document.querySelector("#kiln-bar-chart");
    if (chartElement) {
      const labels = JSON.parse(chartElement.getAttribute('data-labels'));
      const seriesData = JSON.parse(chartElement.getAttribute('data-series'));

      const options = {
        series: [{
          name: 'Total Production',
          data: seriesData
        }],
        chart: {
          type: 'bar',
          height: 350,
          toolbar: { show: false },
          animations: { enabled: true }
        },
        plotOptions: {
          bar: {
            borderRadius: 6,
            horizontal: false,
            columnWidth: '60%',
            distributed: true, // Warna berbeda tiap batang
          }
        },
        dataLabels: { enabled: false },
        colors: ['#0d9488', '#1e40af', '#14b8a6', '#3b82f6'], // Palet Teal & Blue
        xaxis: {
          categories: labels,
          labels: { style: { fontWeight: 600 } }
        },
        yaxis: {
          title: { text: 'Tons (Total)' },
          labels: {
            formatter: (val) => val.toLocaleString('id-ID')
          }
        },
        tooltip: {
          y: {
            formatter: (val) => val.toLocaleString('id-ID') + " Tons"
          }
        }
      };

      const chart = new ApexCharts(chartElement, options);
      chart.render();
    }
  </script>
</Layout>