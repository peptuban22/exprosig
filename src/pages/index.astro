---
import Layout from '~/layouts/PageLayout.astro';
import Papa from 'papaparse';

const metadata = { title: 'Exprosig — Dashboard Performance' };

let stats = [];
let errorMsg = "";

try {
  const response = await fetch('https://docs.google.com/spreadsheets/d/12Qy1QBVDLG9g1VgySGML5EgQc-90rHhw_JT58_eta6Q/export?format=csv&gid=0');
  
  if (!response.ok) throw new Error("Gagal mengambil data dari Google Sheets");
  
  const csvString = await response.text();

  const { data } = Papa.parse(csvString, { 
    header: true, 
    skipEmptyLines: true 
  });

  const getMaxProduction = (kilnName) => {
    const kilnData = data.filter(row => row.KILN === kilnName);
    
    const productions = kilnData.map(row => {
      // Membersihkan karakter jika ada titik/koma ribuan agar bisa diparse
      const cleanValue = row.Production ? row.Production.replace(/[^0-9.-]+/g, "") : "0";
      return parseFloat(cleanValue) || 0;
    });

    return productions.length > 0 ? Math.max(...productions) : 0;
  };

  stats = [
    { title: 'Max Production Kiln 1', amount: getMaxProduction('Kiln 1') },
    { title: 'Max Production Kiln 2', amount: getMaxProduction('Kiln 2') },
    { title: 'Max Production Kiln 3', amount: getMaxProduction('Kiln 3') },
    { title: 'Max Production Kiln 4', amount: getMaxProduction('Kiln 4') },
  ];
} catch (e) {
  errorMsg = e.message;
}
---

<Layout metadata={metadata}>
  <section class="px-4 py-16 mx-auto max-w-7xl">
    {errorMsg ? (
      <div class="p-4 bg-red-100 text-red-700 rounded-lg">Error: {errorMsg}</div>
    ) : (
      <>
        <div class="max-w-xl mb-10 md:mx-auto sm:text-center lg:max-w-2xl md:mb-12">
          <h2 class="text-3xl font-bold leading-tighter tracking-tighter mb-4 font-heading">
            Kiln Production Summary 2026
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {stats.map(({ title, amount }) => (
            <div class="flex flex-col p-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg shadow-sm">
              <p class="text-sm font-medium uppercase tracking-widest text-teal-600 dark:text-teal-400">{title}</p>
              <p class="text-3xl font-bold mt-2">
                {new Intl.NumberFormat('id-ID').format(amount)} <span class="text-sm font-normal text-muted">Tons</span>
              </p>
            </div>
          ))}
        </div>
      </>
    )}
  </section>
</Layout>