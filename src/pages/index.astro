---
import Layout from '~/layouts/PageLayout.astro';

const metadata = { title: 'Exprosig — Dashboard Performance' };
---

<Layout metadata={metadata}>
  <section class="px-4 py-16 mx-auto max-w-7xl">
    <div class="max-w-xl mb-10 md:mx-auto sm:text-center lg:max-w-2xl md:mb-12">
      <h2 class="text-3xl font-bold leading-tighter tracking-tighter mb-4 font-heading">
        Kiln Production Performance 2026
      </h2>
      <p class="text-muted dark:text-slate-400">Data dinamis dari Google Sheets (Updated Daily via ETL).</p>
      <p id="last-updated" class="text-xs text-teal-600 font-medium mt-2 italic"></p>
    </div>

    <div id="scorecard-container" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      {[1, 2, 3, 4].map(() => (
        <div class="animate-pulse flex flex-col p-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg shadow-sm">
          <div class="h-2 bg-slate-200 rounded w-1/2 mb-4"></div>
          <div class="h-6 bg-slate-200 rounded w-3/4"></div>
        </div>
      ))}
    </div>

    <div class="p-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg shadow-sm">
      <h3 class="text-xl font-bold mb-6 text-center text-slate-800 dark:text-white">Visualisasi Perbandingan Produksi</h3>
      <div id="kiln-bar-chart"></div>
    </div>
  </section>

  <script>
    import Papa from 'papaparse';
    import ApexCharts from 'apexcharts';

    async function initDashboard() {
      const sheetUrl = 'https://docs.google.com/spreadsheets/d/12Qy1QBVDLG9g1VgySGML5EgQc-90rHhw_JT58_eta6Q/export?format=csv&gid=0';
      const kilnList = ['Kiln 1', 'Kiln 2', 'Kiln 3', 'Kiln 4'];
      
      try {
        const response = await fetch(sheetUrl);
        const csvString = await response.text();
        
        const { data } = Papa.parse(csvString, { 
          header: true, 
          skipEmptyLines: true 
        });

        // 1. Hitung Total Produksi
        const stats = kilnList.map(kiln => {
          const total = data
            .filter(row => row.KILN === kiln)
            .reduce((sum, row) => {
              const cleanValue = row.Production ? row.Production.replace(/[^0-9.-]+/g, "") : "0";
              return sum + (parseFloat(cleanValue) || 0);
            }, 0);
          return { name: kiln, total: total };
        });

        // 2. Update Scorecards di HTML
        const container = document.querySelector('#scorecard-container');
        if (container) {
          container.innerHTML = stats.map(s => `
            <div class="flex flex-col p-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg shadow-sm">
              <p class="text-xs font-medium uppercase tracking-widest text-teal-600 dark:text-teal-400">Total Production ${s.name}</p>
              <p class="text-2xl font-bold mt-2">
                ${Math.round(s.total).toLocaleString('id-ID')} <span class="text-sm font-normal text-muted">Tons</span>
              </p>
            </div>
          `).join('');
        }

        // 3. Update Timestamp
        const timeElement = document.querySelector('#last-updated');
        if (timeElement) {
          timeElement.innerText = `Data Source Refreshed: ${new Date().toLocaleString('id-ID')} WIB`;
        }

        // 4. Render Chart
        renderChart(stats);

      } catch (error) {
        console.error("Gagal memuat data:", error);
      }
    }

    function renderChart(stats) {
      const options = {
        series: [{
          name: 'Total Production',
          data: stats.map(s => s.total)
        }],
        chart: {
          type: 'bar',
          height: 350,
          toolbar: { show: false }
        },
        plotOptions: {
          bar: { borderRadius: 6, distributed: true, columnWidth: '60%' }
        },
        colors: ['#0d9488', '#1e40af', '#14b8a6', '#3b82f6'],
        xaxis: {
          categories: stats.map(s => s.name),
        },
        yaxis: {
          labels: { formatter: (val) => val.toLocaleString('id-ID') }
        },
        tooltip: {
          y: { formatter: (val) => val.toLocaleString('id-ID') + " Tons" }
        }
      };

      const chart = new ApexCharts(document.querySelector("#kiln-bar-chart"), options);
      chart.render();
    }

    // Jalankan saat halaman dimuat
    initDashboard();
  </script>
</Layout>